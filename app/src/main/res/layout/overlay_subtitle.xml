<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="8dp">

    <!-- Barra superior: título + controles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌐 SubTraductor"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:paddingStart="4dp"/>

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="@android:color/transparent"
            android:contentDescription="Historial"/>

        <ImageButton
            android:id="@+id/btnMinimize"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="@android:color/transparent"
            android:contentDescription="Pausar"/>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:contentDescription="Cerrar"/>

    </LinearLayout>

    <!-- Zona deslizable de historial (oculta por defecto) -->
    <ScrollView
        android:id="@+id/scrollHistory"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:visibility="gone"
        android:fadeScrollbars="false"
        android:scrollbarStyle="insideOverlay">

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:lineSpacingMultiplier="1.3"
            android:fontFamily="sans-serif"/>

    </ScrollView>

    <!-- Separador (visible solo cuando historial está abierto) -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:visibility="gone"
        android:layout_marginBottom="4dp"/>

    <!-- Transcripción original (pequeña) -->
    <TextView
        android:id="@+id/tvOriginal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#77FFFFFF"
        android:textSize="11sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Traducción actual (principal) -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎙️ Escuchando..."
        android:textColor="#FFFFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="8dp"
        android:lineSpacingMultiplier="1.2"
        android:maxLines="3"
        android:ellipsize="end"/>

</LinearLayout>
