<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌐 SubTraductor"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subtítulos en español en tiempo real"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idioma de origen"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:paddingBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerSourceLang"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2A2A2A"
            android:popupBackground="#2A2A2A"
            android:paddingStart="12dp"/>

        <TextView
            android:id="@+id/tvFontSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tamaño texto: 18sp"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:paddingTop="20dp"
            android:paddingBottom="6dp"/>

        <SeekBar
            android:id="@+id/seekBarFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mostrar texto original"
                android:textColor="#CCCCCC"
                android:textSize="14sp"/>

            <Switch
                android:id="@+id/switchAutoDetect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ Los subtítulos aparecerán flotando sobre cualquier app. Arrastra el panel para reposicionarlo."
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Listo para iniciar"
            android:textColor="#4FC3F7"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶ Iniciar subtítulos"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#43A047"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Tip: Para mejor traducción offline de más idiomas, instala Google Translate y descarga los paquetes de idioma."
            android:textColor="#666666"
            android:textSize="11sp"
            android:paddingTop="20dp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
